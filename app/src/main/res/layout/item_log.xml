<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#1E293B"
    android:padding="12dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <!-- Status Light Dot -->
        <View
            android:id="@+id/vStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="#34D399"
            android:layout_marginEnd="8dp"/>

        <!-- App Name -->
        <TextView
            android:id="@+id/tvLogAppName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="WhatsApp"
            android:textColor="#E2E8F0"
            android:textStyle="bold"
            android:textSize="14sp"/>

        <!-- Test Badge -->
        <TextView
            android:id="@+id/tvTestBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEST"
            android:textColor="#0F172A"
            android:background="#F59E0B"
            android:textSize="9sp"
            android:textStyle="bold"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone"/>

        <!-- Timestamp -->
        <TextView
            android:id="@+id/tvLogTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12:30:15"
            android:textColor="#64748B"
            android:textSize="11sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvLogNotifDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Joni: Sukses masuk transfer sebesar Rp 10.000"
        android:textColor="#94A3B8"
        android:textSize="12sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="6dp"/>

    <!-- Bottom details: HTTP Code and URL -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Status Code Badge -->
        <TextView
            android:id="@+id/tvLogStatusCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200"
            android:textColor="#0F172A"
            android:background="#34D399"
            android:textStyle="bold"
            android:textSize="10sp"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_marginEnd="8dp"/>

        <!-- URL -->
        <TextView
            android:id="@+id/tvLogApiUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="https://api.yourserver.com/endpoint"
            android:textColor="#38BDF8"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:fontFamily="monospace"/>
    </LinearLayout>

</LinearLayout>
