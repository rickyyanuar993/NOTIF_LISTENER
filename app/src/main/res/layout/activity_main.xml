<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F172A">

    <LinearLayout
        android:id="@+id/layoutDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Title Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔 Notif Listener"
                android:textSize="26sp"
                android:textColor="#38BDF8"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forward Notifications to your Server API in Real-Time"
                android:textSize="12sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Navigation & Quick Stats Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E293B"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 UTILITY &amp; LOGS"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp"/>

                    <Button
                        android:id="@+id/btnOpenLogViewer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="📋 Buka Log Viewer Khusus"
                        android:textSize="13sp"
                        android:textColor="#0F172A"
                        android:backgroundTint="#F59E0B"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Halaman khusus untuk melihat riwayat data JSON terkirim dan respons dari server."
                        android:textColor="#64748B"
                        android:textSize="10sp"
                        android:gravity="center_horizontal"/>
                </LinearLayout>

                <!-- API Configuration Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E293B"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐 CONFIG TARGET API"
                        android:textColor="#38BDF8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="API URL"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"/>

                    <EditText
                        android:id="@+id/etApiUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="https://api.yourserver.com/endpoint"
                        android:textColor="#E2E8F0"
                        android:textColorHint="#475569"
                        android:inputType="textUri"
                        android:textSize="14sp"
                        android:layout_marginBottom="12dp"
                        android:backgroundTint="#38BDF8"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Custom Headers (Format: Key: Value)"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:layout_marginBottom="6dp"/>

                    <!-- Common Header Helper Chips -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:layout_marginBottom="8dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/chipHeaderJson"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+ Content-Type: JSON"
                                android:textColor="#E2E8F0"
                                android:textSize="10sp"
                                android:background="#334155"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="6dp"
                                android:clickable="true"/>

                            <TextView
                                android:id="@+id/chipHeaderAuth"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+ Authorization: Bearer"
                                android:textColor="#E2E8F0"
                                android:textSize="10sp"
                                android:background="#334155"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="6dp"
                                android:clickable="true"/>

                            <TextView
                                android:id="@+id/chipHeaderApiKey"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+ X-Api-Key"
                                android:textColor="#E2E8F0"
                                android:textSize="10dp"
                                android:background="#334155"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:layout_marginEnd="6dp"
                                android:clickable="true"/>

                            <TextView
                                android:id="@+id/chipHeaderUserAgent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+ User-Agent"
                                android:textColor="#E2E8F0"
                                android:textSize="10sp"
                                android:background="#334155"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:clickable="true"/>
                        </LinearLayout>
                    </HorizontalScrollView>

                    <EditText
                        android:id="@+id/etApiHeaders"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:hint="Content-Type: application/json&#10;Authorization: Bearer mytoken"
                        android:textColor="#E2E8F0"
                        android:textColorHint="#475569"
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:textSize="12sp"
                        android:backgroundTint="#38BDF8"/>
                </LinearLayout>

                <!-- Background Optimizations Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E293B"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚡ OPTIMASI LATAR BELAKANG"
                        android:textColor="#F43F5E"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Agar aplikasi terus berjalan tanpa dihentikan sistem Android secara paksa saat HP idle."
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <Button
                            android:id="@+id/btnOptimizeBattery"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🔋 Pengaturan Baterai"
                            android:textSize="11sp"
                            android:textColor="#0F172A"
                            android:backgroundTint="#34D399"
                            android:layout_marginEnd="4dp"/>

                        <Button
                            android:id="@+id/btnOptimizeData"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="📶 Batasan Data Saver"
                            android:textSize="11sp"
                            android:textColor="#0F172A"
                            android:backgroundTint="#38BDF8"
                            android:layout_marginStart="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvBatteryStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Status Baterai: Menghubungkan..."
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:gravity="center_horizontal"/>
                </LinearLayout>

                <!-- App Filter Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E293B"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📦 FILTER APLIKASI SUMBER"
                        android:textColor="#818CF8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="8dp"/>

                    <RadioGroup
                        android:id="@+id/rgAppFilterMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="10dp">

                        <RadioButton
                            android:id="@+id/rbAppAll"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Semua Aplikasi"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:buttonTint="#818CF8"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/rbAppSpecific"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Aplikasi Tertentu"
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:buttonTint="#818CF8"/>
                    </RadioGroup>

                    <!-- Specific App List Container -->
                    <LinearLayout
                        android:id="@+id/layoutSpecificApps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <CheckBox
                                android:id="@+id/chkSourceWa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="#34D399"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WhatsApp"
                                android:textColor="#E2E8F0"
                                android:textSize="13sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">
                            <CheckBox
                                android:id="@+id/chkSourceDana"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="#34D399"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DANA"
                                android:textColor="#E2E8F0"
                                android:textSize="13sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">
                            <CheckBox
                                android:id="@+id/chkSourceOvo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="#34D399"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OVO"
                                android:textColor="#E2E8F0"
                                android:textSize="13sp"
                                android:layout_marginStart="6dp"/>
                        </LinearLayout>

                        <!-- Custom select button -->
                        <Button
                            android:id="@+id/btnSelectOtherApps"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="🔍 Pilih Aplikasi Lain..."
                            android:textSize="12sp"
                            android:textColor="#0F172A"
                            android:backgroundTint="#818CF8"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/tvSelectedOtherApps"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Tidak ada aplikasi tambahan dipilih"
                            android:textColor="#64748B"
                            android:textSize="11sp"
                            android:layout_marginTop="6dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Keyword Filters Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E293B"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🔍 FILTER KATA KUNCI ISI NOTIF"
                            android:textColor="#34D399"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <Switch
                            android:id="@+id/swKeywordFilterEnabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="#34D399"
                            android:trackTint="#334155"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutKeywordConfig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kata Kunci (Pisahkan dengan koma)"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"/>

                        <EditText
                            android:id="@+id/etKeywords"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="sukses, transfer, dana, masuk, Rp"
                            android:textColor="#E2E8F0"
                            android:textColorHint="#475569"
                            android:textSize="14sp"
                            android:backgroundTint="#34D399"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cocokkan jika isi notifikasi mengandung kata kunci di atas (tidak sensitif huruf besar/kecil)."
                            android:textColor="#64748B"
                            android:textSize="11sp"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Clear Notification Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E293B"
                    android:padding="16dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="🧹 BERSIHKAN NOTIFIKASI OTOMATIS"
                            android:textColor="#F59E0B"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"/>

                        <Switch
                            android:id="@+id/swAutoClearEnabled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:thumbTint="#F59E0B"
                            android:trackTint="#334155"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutAutoClearConfig"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jeda Bersihkan Notifikasi (Detik setelah API dipicu)"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"/>

                        <EditText
                            android:id="@+id/etClearDelay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="5"
                            android:textColor="#E2E8F0"
                            android:textColorHint="#475569"
                            android:inputType="number"
                            android:textSize="14sp"
                            android:backgroundTint="#F59E0B"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Terminal Console Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#020617"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="💻 CONSOLE LOG TRAFFIC"
                            android:textColor="#F43F5E"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"/>

                        <TextView
                            android:id="@+id/btnClearConsole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CLEAR"
                            android:textColor="#475569"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:padding="4dp"
                            android:clickable="true"/>
                    </LinearLayout>

                    <ScrollView
                        android:id="@+id/scrollConsole"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:scrollbars="vertical">

                        <TextView
                            android:id="@+id/tvConsoleLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#E2E8F0"
                            android:textSize="11sp"
                            android:fontFamily="monospace"
                            android:text="[System] Welcome to Notif Listener. Waiting for traffic...\n"
                            android:lineSpacingMultiplier="1.2"/>
                    </ScrollView>
                </LinearLayout>

                <!-- Bottom Save & Test Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <Button
                        android:id="@+id/btnSaveConfig"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="💾 Simpan Konfigurasi"
                        android:textSize="11sp"
                        android:textColor="#0F172A"
                        android:backgroundTint="#34D399"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnTestApi"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="⚡ Kirim Test API"
                        android:textSize="11sp"
                        android:textColor="#0F172A"
                        android:backgroundTint="#38BDF8"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- ═══ PERMISSION GATE SCREEN ═══ -->
    <LinearLayout
        android:id="@+id/layoutGate"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#0F172A"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔔"
            android:textSize="80sp"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Akses Notifikasi Diperlukan"
            android:textSize="22sp"
            android:textColor="#E2E8F0"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aplikasi ini memerlukan izin membaca notifikasi dari sistem agar dapat menangkap dan meneruskan notifikasi Anda ke target API."
            android:textSize="13sp"
            android:textColor="#94A3B8"
            android:gravity="center"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnGateGrantNotification"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Aktifkan Akses Notifikasi"
            android:textSize="15sp"
            android:textColor="#0F172A"
            android:backgroundTint="#38BDF8"/>

    </LinearLayout>

</FrameLayout>
